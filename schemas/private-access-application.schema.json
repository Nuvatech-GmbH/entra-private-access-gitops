{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/private-access-application.schema.json",
  "title": "Microsoft Entra Private Access Application (Desired State)",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "gsa.gitops/v1"
    },
    "kind": {
      "type": "string",
      "const": "PrivateAccessApplication"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "owners", "changeReference"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 3,
          "maxLength": 120,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._\\- ]{2,119}$"
        },
        "description": { "type": "string", "maxLength": 1024 },
        "tags": {
          "type": "object",
          "additionalProperties": { "type": "string", "maxLength": 256 }
        },
        "owners": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$"
          }
        },
        "changeReference": {
          "type": "string",
          "minLength": 4,
          "maxLength": 128,
          "description": "Externe Nachverfolgbarkeit (z. B. Azure DevOps Work Item, Jira, ServiceNow CHG)."
        },
        "graphApplicationId": {
          "type": "string",
          "format": "uuid",
          "description": "Optional: Bindung an bestehende Graph Application (Import / Reconciliation)."
        },
        "graphServicePrincipalId": {
          "type": "string",
          "format": "uuid",
          "description": "Optional: Service Principal Object ID (falls bekannt)."
        }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["applicationType", "connectorGroup", "destinations", "assignments"],
      "properties": {
        "applicationType": {
          "type": "string",
          "enum": ["enterprise", "quickAccess"],
          "description": "enterprise = nonwebapp, quickAccess = quickaccessapp (siehe Microsoft Learn Tutorial Private Access)."
        },
        "isAccessibleViaZTNAClient": { "type": "boolean", "default": true },
        "isDnsResolutionEnabled": {
          "type": "boolean",
          "description": "Nur für Quick Access relevant (laut Microsoft-Dokumentation)."
        },
        "connectorGroup": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "description": "Name der Connector Group (Application Proxy) im Mandanten."
        },
        "destinations": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/destination" }
        },
        "assignments": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/assignment" }
        }
      }
    }
  },
  "$defs": {
    "destination": {
      "type": "object",
      "additionalProperties": false,
      "required": ["host", "type", "ports", "protocol"],
      "properties": {
        "host": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512,
          "description": "FQDN, DNS-Suffix, IP, CIDR oder Bereich je nach type."
        },
        "type": {
          "type": "string",
          "enum": ["fqdn", "dnsSuffix", "ipAddress", "ipRange", "ipRangeCidr"]
        },
        "ports": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^(\\d+|\\d+-\\d+)$"
          }
        },
        "protocol": {
          "type": "string",
          "enum": ["tcp", "udp", "tcp,udp"]
        }
      }
    },
    "assignment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["principalType"],
      "properties": {
        "principalType": { "type": "string", "enum": ["User", "Group", "ServicePrincipal"] },
        "principalId": { "type": "string", "format": "uuid" },
        "principalName": {
          "type": "string",
          "minLength": 3,
          "description": "Optional: UPN (User) oder Gruppenname (Group) – Auflösung erfolgt beim Deployment."
        }
      },
      "description": "Entweder principalId (empfohlen) oder principalName (nur User/Group) muss gesetzt sein (zusätzliche Prüfung in Invoke-GSAValidation.ps1)."
    }
  }
}
